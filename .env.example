# NEXT_PUBLIC_GEMINI_API_KEY: Required for Gemini AI API calls when using Next.js.
NEXT_PUBLIC_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_API_KEY: Required for Gemini AI API calls in local/AI Studio environment.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_GEMINI_API_KEY: Required for Gemini AI API calls when deployed to Vercel/Vite.
# In Vercel, add this to your Environment Variables.
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
